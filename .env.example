# 复制为 .env 并填入真实值。切勿提交到版本库。

# Flask session 密钥（随便一段长随机串）
AEGIS_SECRET_KEY=change-me-to-a-long-random-string

# Fernet 主密钥，用于加密凭证与 API Key。
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 警告：此密钥丢失将导致所有已加密数据无法解密，请务必备份。
AEGIS_MASTER_KEY=

# 数据库路径（默认 sqlite:///aegis.db）
AEGIS_DATABASE_URI=sqlite:///aegis.db

# 运行环境：development / production
AEGIS_ENV=development

# 云浏览器 noVNC 地址（部署 deploy/cloud-browser 容器后填写；留空则该工具显示未配置提示）
AEGIS_CLOUD_BROWSER_URL=
AEGIS_CLOUD_BROWSER_CONTAINER=aegis-cloud-browser
